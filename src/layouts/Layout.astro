---
import '../styles/global.css';
import Comments from '../components/Comments.astro';
const { frontmatter, headings } = Astro.props;

// Metadata Extraction
const title = frontmatter?.title || Astro.props.title || "Jeffrey Patton | Cloud Architect";
const pubDate = frontmatter?.pubDate;

// Reading Time Logic
const wordsPerMinute = 200;
const rawContent = Astro.props.rawContent ? Astro.props.rawContent() : "";
const wordCount = rawContent.split(/\s+/g).length > 1 ? rawContent.split(/\s+/g).length : 450;
const readingTime = Math.ceil(wordCount / wordsPerMinute);

// Date Formatting
const displayDate = pubDate 
  ? new Date(pubDate).toLocaleDateString('en-us', {
      year: 'numeric',
      month: 'long',
      day: 'numeric',
    })
  : null;

// Filter headings for TOC (only H2 and H3)
const toc = headings?.filter((h) => h.depth > 1 && h.depth < 4);
---
<!doctype html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width" />
		<title>{title}</title>
		<script is:inline>
			const theme = (() => {
				if (typeof localStorage !== 'undefined' && localStorage.getItem('theme')) {
					return localStorage.getItem('theme');
				}
				return window.matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light';
			})();
			document.documentElement.classList.toggle('dark', theme === 'dark');
		</script>
	</head>
	<body class="bg-white text-slate-900 dark:bg-black dark:text-slate-100 transition-colors duration-300 antialiased font-sans">
		<main class="max-w-4xl mx-auto px-6 py-12">
			<nav class="flex justify-between items-center mb-16 border-b border-slate-200 dark:border-slate-800 pb-8">
				<div>
					<a href="/" class="group">
						<h1 class="text-5xl md:text-6xl font-black tracking-tighter text-slate-900 dark:text-white leading-none">
							Patton <span class="text-blue-600 dark:text-blue-500">Tech</span> Blog
						</h1>
					</a>
				</div>
				<div class="flex items-center gap-6">
					<a href="/rss.xml" class="text-slate-500 hover:text-blue-600 dark:text-slate-400 dark:hover:text-blue-500 transition-colors" title="RSS Feed">
						<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 11a9 9 0 0 1 9 9"></path><path d="M4 4a16 16 0 0 1 16 16"></path><circle cx="5" cy="19" r="1"></circle></svg>
					</a>
					<button id="themeToggle" class="text-slate-500 hover:text-blue-600 dark:text-slate-400 dark:hover:text-blue-500 transition-colors">
						<svg id="sunIcon" class="hidden dark:block" xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="4"></circle><path d="M12 2v2"></path><path d="M12 20v2"></path><path d="m4.93 4.93 1.41 1.41"></path><path d="m17.66 17.66 1.41 1.41"></path><path d="M2 12h2"></path><path d="M20 12h2"></path><path d="m6.34 17.66-1.41 1.41"></path><path d="m19.07 4.93-1.41 1.41"></path></svg>
						<svg id="moonIcon" class="block dark:hidden" xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 3a6 6 0 0 0 9 9 9 9 0 1 1-9-9Z"></path></svg>
					</button>
				</div>
			</nav>

			{displayDate && (
				<header class="mb-8">
					<div class="flex items-center gap-2 text-sm font-medium text-slate-500 dark:text-slate-400 mb-4">
						<span>By Jeff Patton</span>
						<span>•</span>
						<time datetime={pubDate}>{displayDate}</time>
						<span>•</span>
						<span>{readingTime} min read</span>
					</div>
					
					{toc && toc.length > 0 && (
						<aside class="bg-slate-50 dark:bg-slate-900/50 border border-slate-200 dark:border-slate-800 rounded-lg p-6 my-8">
							<h2 class="text-sm font-bold uppercase tracking-widest text-slate-400 mb-4 mt-0">Table of Contents</h2>
							<ul class="list-none p-0 m-0 space-y-2">
								{toc.map((heading) => (
									<li class={`text-sm ${heading.depth === 3 ? 'ml-4' : ''}`}>
										<a href={`#${heading.slug}`} class="text-blue-600 dark:text-blue-500 hover:underline">
											{heading.text}
										</a>
									</li>
								))}
							</ul>
						</aside>
					)}
				</header>
			)}

			<article class="prose prose-slate prose-lg dark:prose-invert max-w-none">
				<slot />
			</article>
			
			{pubDate && (
				<footer class="mt-16 pt-8 border-t border-slate-200 dark:border-slate-800">
					<div class="bg-slate-50 dark:bg-slate-900/50 rounded-xl p-8 flex flex-col md:flex-row gap-6 items-center">
						<div class="w-20 h-20 bg-blue-600 rounded-full flex items-center justify-center text-white text-2xl font-black">JP</div>
						<div class="flex-1 text-center md:text-left">
							<h3 class="text-xl font-bold mb-2">About Jeff Patton</h3>
							<p class="text-slate-600 dark:text-slate-400 text-sm leading-relaxed mb-4">
								Cloud Architect at Veritium Corp and certified home inspector. Specializing in AWS Control Tower, cloud governance, and cybersecurity infrastructure.
							</p>
							<div class="flex justify-center md:justify-start gap-4">
								<a href="https://github.com/Junior6621" class="text-xs font-bold text-blue-600 dark:text-blue-500 uppercase tracking-tighter">GitHub</a>
								<a href="/rss.xml" class="text-xs font-bold text-blue-600 dark:text-blue-500 uppercase tracking-tighter">RSS</a>
							</div>
						</div>
					</div>
					<div class="mt-12">
						<Comments />
					</div>
				</footer>
			)}
		</main>

		<script>
			const themeToggle = document.getElementById('themeToggle');
			themeToggle?.addEventListener('click', () => {
				const isDark = document.documentElement.classList.toggle('dark');
				localStorage.setItem('theme', isDark ? 'dark' : 'light');
			});
		</script>
	</body>
</html>
