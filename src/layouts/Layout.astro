---
import '../styles/global.css';
import Comments from '../components/Comments.astro';
const { frontmatter } = Astro.props;

// Metadata Extraction
const title = frontmatter?.title || Astro.props.title || "Jeffrey Patton | Cloud Architect";
const pubDate = frontmatter?.pubDate;

// Reading Time Logic (Approx 200 words per minute)
const wordsPerMinute = 200;
const rawContent = Astro.props.rawContent ? Astro.props.rawContent() : "";
const wordCount = rawContent.split(/\s+/g).length > 1 ? rawContent.split(/\s+/g).length : 450;
const readingTime = Math.ceil(wordCount / wordsPerMinute);

// Date Formatting
const displayDate = pubDate 
  ? new Date(pubDate).toLocaleDateString('en-us', {
      year: 'numeric',
      month: 'long',
      day: 'numeric',
    })
  : null;
---
<!doctype html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width" />
		<title>{title}</title>
		<script is:inline>
			const theme = (() => {
				if (typeof localStorage !== 'undefined' && localStorage.getItem('theme')) {
					return localStorage.getItem('theme');
				}
				return window.matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light';
			})();
			document.documentElement.classList.toggle('dark', theme === 'dark');
		</script>
	</head>
	<body class="bg-white text-slate-900 dark:bg-black dark:text-slate-100 transition-colors duration-300 antialiased font-sans">
		<main class="max-w-4xl mx-auto px-6 py-12">
			<nav class="flex justify-between items-start mb-16 border-b border-slate-200 dark:border-slate-800 pb-8">
				<div>
					<a href="/" class="group">
						<h1 class="text-5xl md:text-6xl font-black tracking-tighter text-slate-900 dark:text-white leading-none">
							Patton <span class="text-blue-600 dark:text-blue-500">Tech</span> Blog
						</h1>
					</a>
				</div>
				<div class="flex items-center gap-6 mt-2">
					<form id="newsletterForm" class="hidden md:flex items-center gap-2">
						<input type="email" id="subEmail" placeholder="Email" class="bg-slate-100 dark:bg-slate-900 border border-slate-200 dark:border-slate-800 rounded px-3 py-1 text-xs outline-none w-40" required />
						<button type="submit" id="subBtn" class="text-xs font-bold text-blue-600 dark:text-blue-500">Join</button>
					</form>
				</div>
			</nav>

			{displayDate && (
				<div class="mb-8 flex items-center gap-2 text-sm font-medium text-slate-500 dark:text-slate-400">
					<time datetime={pubDate}>{displayDate}</time>
					<span>•</span>
					<span>{readingTime} min read</span>
				</div>
			)}

			<article class="prose prose-slate prose-lg dark:prose-invert max-w-none">
				<slot />
			</article>
			
			{pubDate && <div class="mt-16 pt-8 border-t border-slate-200 dark:border-slate-800">
				<Comments />
			</div>}
		</main>

		<script define:vars={{ apiURL: "https://ck6jfryidd.execute-api.us-east-1.amazonaws.com/prod/subscribe" }}>
			const form = document.getElementById('newsletterForm');
			if (form) {
				form.addEventListener('submit', async (e) => {
					e.preventDefault();
					const emailInput = document.getElementById('subEmail');
					const btn = document.getElementById('subBtn');
					btn.innerText = '...';
					btn.disabled = true;

					try {
						const response = await fetch(apiURL, {
							method: 'POST',
							mode: 'cors',
							headers: { 'Content-Type': 'application/json' },
							body: JSON.stringify({ email: emailInput.value.trim() })
						});

						const text = await response.text();
						if (response.ok) {
							alert('Success! Check your inbox.');
							form.reset();
						} else {
							throw new Error(text || 'Server error');
						}
					} catch (err) {
						alert(`Error: ${err.message}`);
					} finally {
						btn.innerText = 'Join';
						btn.disabled = false;
					}
				});
			}
		</script>
	</body>
</html>
