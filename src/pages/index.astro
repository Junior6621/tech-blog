---
import Layout from '../layouts/Layout.astro';
import { getCollection } from 'astro:content';

// Fetch all posts from the new 'blog' collection
const posts = await getCollection('blog');

// Sort by pubDate descending (newest first)
const sortedPosts = posts.sort((a, b) => 
  b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
);
---

<Layout title="Jeffrey Patton | AWS Solutions Architect">
	<section class="mb-12">
		<h1 class="text-4xl font-extrabold mb-4 text-slate-900 dark:text-white leading-tight">
			Cloud Architecture & Security
		</h1>
		<p class="text-lg text-slate-600 dark:text-slate-400 max-w-2xl">
			Technical insights, AWS Control Tower recoveries, and cybersecurity deep dives for the modern IT professional.
		</p>
	</section>

	<div class="space-y-16">
		{sortedPosts.map((post) => (
			<article class="group relative flex flex-col items-start">
				<div class="flex flex-col md:flex-row md:items-baseline justify-between w-full mb-2">
					<h2 class="text-2xl font-bold group-hover:text-blue-600 dark:group-hover:text-blue-500 transition-colors">
						<a href={`/blog/${post.slug}`}>
							{post.data.title}
						</a>
					</h2>
					<time class="text-sm text-slate-500 dark:text-slate-400 font-mono mt-1 md:mt-0">
						{post.data.pubDate.toLocaleDateString('en-US', {
							year: 'numeric',
							month: 'short',
							day: 'numeric',
						})}
					</time>
				</div>
				<p class="text-slate-600 dark:text-slate-400 mb-4 leading-relaxed line-clamp-3">
					{post.data.description}
				</p>
				<div class="flex flex-wrap gap-2">
					{post.data.tags?.map(tag => (
						<span class="bg-slate-100 dark:bg-slate-900 text-slate-600 dark:text-slate-400 text-[10px] font-black px-2 py-1 rounded uppercase tracking-tighter border border-slate-200 dark:border-slate-800">
							{tag}
						</span>
					))}
				</div>
			</article>
		))}
	</div>
</Layout>
